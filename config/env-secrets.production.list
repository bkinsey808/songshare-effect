# All vars for the production environment — read from keyring service "songshare-production"
# Add missing entries with: keyring set songshare-production <NAME> <value>

# Cloudflare
CLOUDFLARE_PROJECT
CLOUDFLARE_ZONE_ID
CLOUDFLARE_API_TOKEN
DOMAIN

# Vite build-time vars
VITE_ENVIRONMENT
VITE_BUILD_NUMBER
VITE_APP_BRAND
VITE_APP_NAME
VITE_SUPPORT_EMAIL_ADDRESS
VITE_SEO_APP_TITLE
VITE_SEO_APP_DESCRIPTION
VITE_SEO_APP_KEYWORDS
VITE_SUPABASE_URL
VITE_SUPABASE_ANON_KEY
VITE_API_BASE_URL
VITE_WEB_BASE_URL

# OAuth client IDs (public)
GOOGLE_CLIENT_ID
MS_CLIENT_ID
AMAZON_CLIENT_ID

# Worker runtime vars
STORAGE_BACKEND
VITE_STORAGE_BACKEND
ENVIRONMENT
OAUTH_REDIRECT_ORIGIN
ALLOWED_ORIGINS
ALLOWED_REDIRECT_ORIGINS
REGISTER_COOKIE_CLIENT_DEBUG
DEBUG_API_HEADERS

# Supabase
SUPABASE_PROJECT_REF
SUPABASE_STAGING_PROJECT_REF
SUPABASE_VISITOR_EMAIL
SUPABASE_SERVICE_KEY
SUPABASE_JWT_SECRET
SUPABASE_LEGACY_JWT_SECRET
SUPABASE_VISITOR_PASSWORD
SUPABASE_STAGING_PW
STATE_HMAC_SECRET

# Postgres / migrations
PGHOST
PGPORT
PGUSER
PGDATABASE
PGPASSWORD

# OAuth secrets
GOOGLE_CLIENT_SECRET
MS_CLIENT_SECRET
AMAZON_CLIENT_SECRET

# E2E / testing
PLAYWRIGHT_BASE_URL
